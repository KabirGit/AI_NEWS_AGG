## Copy to .env for local development:
##   cp .env.example .env
##
## Required for ALL environments
APP_ENV=local
LOG_LEVEL=INFO

## Database
## - For local Docker Compose, use host `db`
## - For local running on your machine, use host `localhost`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=news_db
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/news_db

## RSS (optional)
# RSS_URLS=https://news.google.com/rss?hl=en-US&gl=US&ceid=US:en,https://hnrss.org/frontpage

## Recommender weights (optional)
REC_WEIGHT_SIMILARITY=0.6
REC_WEIGHT_RECENCY=0.3
REC_WEIGHT_SOURCE=0.1

## Email sending toggle (used by scheduler)
SEND_EMAILS=false

## Resend (required only if SEND_EMAILS=true)
RESEND_API_KEY=
EMAIL_FROM=

## Optional OpenAI summarization
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

## Optional SMTP (unused if you rely on Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_REPLY_TO=

## Behavior toggles
DRY_RUN_EMAIL=false
